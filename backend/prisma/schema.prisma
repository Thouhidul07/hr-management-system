// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  HR
  MANAGER
  EMPLOYEE
}

enum Status {
  ACTIVE
  INACTIVE
  ON_LEAVE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  PATERNITY
  UNPAID
  BEREAVEMENT
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  LEAVE
}

enum TrainingStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED
}

enum EnrollmentStatus {
  ENROLLED
  COMPLETED
  FAILED
  DROPPED
}

enum PayrollStatus {
  PENDING
  PROCESSED
  PAID
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AssessmentStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  FINALIZED
}

enum PeerReviewStatus {
  DRAFT
  SUBMITTED
  REVIEWED
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  role         Role      @default(EMPLOYEE)
  departmentId Int?
  position     String?
  hireDate     DateTime?
  status       Status    @default(ACTIVE)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  department          Department?      @relation("DepartmentUsers", fields: [departmentId], references: [id])
  employee            Employee?        @relation("UserEmployee")
  managedDepartments  Department[]     @relation("DepartmentManager")
  managedEmployees    Employee[]       @relation("EmployeeManager")
  assignedTasks       OnboardingTask[] @relation("OnboardingAssignee")
  assessmentsGiven    Assessment[]     @relation("AssessmentAssessor")
  peerReviewsGiven    PeerReview[]     @relation("PeerReviewsReviewer")
  approvedExpenses    Expense[]        @relation("ExpenseApprover")
  approvedLeaves      LeaveRequest[]   @relation("LeaveApprover")

  @@map("users")
}

model Department {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  managerId   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  manager User?  @relation("DepartmentManager", fields: [managerId], references: [id])
  users   User[] @relation("DepartmentUsers")

  @@map("departments")
}

model Employee {
  id                       Int      @id @default(autoincrement())
  userId                   Int      @unique
  employeeId               String   @unique
  reportingManagerId       Int?
  jobTitle                 String?
  salary                   Decimal?
  bankAccountNumber        String?
  taxId                    String?
  emergencyContactName     String?
  emergencyContactPhone    String?
  emergencyContactRelation String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  user                 User                 @relation("UserEmployee", fields: [userId], references: [id])
  reportingManager     User?                @relation("EmployeeManager", fields: [reportingManagerId], references: [id])
  attendances          Attendance[]
  leaveRequests        LeaveRequest[]       @relation("EmployeeLeaveRequests")
  trainingEnrollments  TrainingEnrollment[]
  payrollRecords       Payroll[]
  expenses             Expense[]            @relation("EmployeeExpenses")
  assessments          Assessment[]         @relation("AssessmentEmployee")
  peerReviews          PeerReview[]         @relation("PeerReviewsReviewee")
  offboardingProcesses OffboardingProcess[]

  @@map("employees")
}

model OnboardingTask {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  dueDate     DateTime
  status      String   @default("pending")
  assignedTo  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignedUser User? @relation("OnboardingAssignee", fields: [assignedTo], references: [id])

  @@map("onboarding_tasks")
}

model OffboardingProcess {
  id         Int      @id @default(autoincrement())
  employeeId Int
  lastDay    DateTime
  reason     String
  status     String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@map("offboarding_processes")
}

model Attendance {
  id            Int              @id @default(autoincrement())
  employeeId    Int
  date          DateTime
  checkIn       DateTime?
  checkOut      DateTime?
  breakDuration Int              @default(0)
  status        AttendanceStatus @default(PRESENT)
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
  @@map("attendance")
}

model LeaveRequest {
  id         Int         @id @default(autoincrement())
  employeeId Int
  leaveType  LeaveType
  startDate  DateTime
  endDate    DateTime
  totalDays  Decimal     @db.Decimal(5, 2)
  reason     String?
  status     LeaveStatus @default(PENDING)
  approvedBy Int?
  approvedAt DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  employee Employee    @relation("EmployeeLeaveRequests", fields: [employeeId], references: [id])
  approver User?       @relation("LeaveApprover", fields: [approvedBy], references: [id])

  @@map("leave_requests")
}

model Training {
  id              Int            @id @default(autoincrement())
  title           String
  description     String
  startDate       DateTime
  endDate         DateTime
  location        String?
  trainer         String?
  maxParticipants Int?
  status          TrainingStatus @default(SCHEDULED)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  enrollments TrainingEnrollment[]

  @@map("trainings")
}

model TrainingEnrollment {
  id             Int              @id @default(autoincrement())
  trainingId     Int
  employeeId     Int
  enrollmentDate DateTime         @default(now())
  completionDate DateTime?
  status         EnrollmentStatus @default(ENROLLED)
  score          Decimal?         @db.Decimal(5, 2)
  feedback       String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  training Training @relation(fields: [trainingId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([trainingId, employeeId])
  @@map("training_enrollments")
}

model Payroll {
  id             Int           @id @default(autoincrement())
  employeeId     Int
  payPeriodStart DateTime
  payPeriodEnd   DateTime
  basicSalary    Decimal       @db.Decimal(10, 2)
  allowances     Decimal       @db.Decimal(10, 2) @default(0)
  deductions     Decimal       @db.Decimal(10, 2) @default(0)
  overtimePay    Decimal       @db.Decimal(10, 2) @default(0)
  bonus          Decimal       @db.Decimal(10, 2) @default(0)
  tax            Decimal       @db.Decimal(10, 2) @default(0)
  netSalary      Decimal       @db.Decimal(10, 2)
  paymentDate    DateTime?
  status         PayrollStatus @default(PENDING)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, payPeriodStart, payPeriodEnd])
  @@map("payroll")
}

model Expense {
  id          Int           @id @default(autoincrement())
  employeeId  Int
  expenseType String
  amount      Decimal       @db.Decimal(10, 2)
  description String?
  expenseDate DateTime
  receiptUrl  String?
  status      ExpenseStatus @default(PENDING)
  approvedBy  Int?
  approvedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  employee Employee @relation("EmployeeExpenses", fields: [employeeId], references: [id])
  approver User?    @relation("ExpenseApprover", fields: [approvedBy], references: [id])

  @@map("expenses")
}

model Assessment {
  id                    Int              @id @default(autoincrement())
  employeeId            Int
  assessorId            Int
  assessmentPeriodStart DateTime
  assessmentPeriodEnd   DateTime
  overallRating         Decimal?         @db.Decimal(3, 2)
  goalsAchievement      String?
  strengths             String?
  areasForImprovement   String?
  comments              String?
  status                AssessmentStatus @default(DRAFT)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  employee Employee @relation("AssessmentEmployee", fields: [employeeId], references: [id])
  assessor User     @relation("AssessmentAssessor", fields: [assessorId], references: [id])

  @@map("assessments")
}

model PeerReview {
  id                   Int              @id @default(autoincrement())
  reviewerId           Int
  revieweeId           Int
  reviewPeriodStart    DateTime
  reviewPeriodEnd      DateTime
  teamworkRating       Decimal?         @db.Decimal(3, 2)
  communicationRating  Decimal?         @db.Decimal(3, 2)
  problemSolvingRating Decimal?         @db.Decimal(3, 2)
  leadershipRating     Decimal?         @db.Decimal(3, 2)
  adaptabilityRating   Decimal?         @db.Decimal(3, 2)
  comments             String?
  isAnonymous          Boolean          @default(false)
  status               PeerReviewStatus @default(DRAFT)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  reviewer User     @relation("PeerReviewsReviewer", fields: [reviewerId], references: [id])
  reviewee Employee @relation("PeerReviewsReviewee", fields: [revieweeId], references: [id])

  @@unique([reviewerId, revieweeId, reviewPeriodStart, reviewPeriodEnd])
  @@map("peer_reviews")
}